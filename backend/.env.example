# Tavus API credentials — see docs.md Section 8 for full setup walkthrough
TAVUS_API_KEY=your_tavus_api_key_here

# Identity for video conversations (provide at least one)
# Recommended: create a PAL in Tavus dashboard and use its ID
TAVUS_PAL_ID=your_pal_id_here
TAVUS_FACE_ID=your_face_id_here

# Legacy alias — still supported if your dashboard shows "replica_id"
TAVUS_REPLICA_ID=your_replica_or_face_id_here

# Server port (optional, defaults to 3001)
PORT=3001

# CORS (optional): comma-separated allowlist of frontend origins for production.
# Leave unset for open CORS in local dev.
# CORS_ORIGINS=https://your-app.lovable.app,https://preview.lovable.app
